#!/usr/bin/env bash
set -euo pipefail

REMOTE_NAME="${1:-}"
REMOTE_URL="${2:-}"

WEBHOOK_URL="${SIARD_WEBHOOK_URL:-$(git config --local --get siard.webhookUrl || true)}"
WEBHOOK_SECRET="${SIARD_WEBHOOK_SECRET:-$(git config --local --get siard.webhookSecret || true)}"
WEBHOOK_BRANCH="${SIARD_WEBHOOK_BRANCH:-$(git config --local --get siard.webhookBranch || echo main)}"
WEBHOOK_DELAY_SECONDS="${SIARD_WEBHOOK_DELAY_SECONDS:-8}"

if [[ -z "$WEBHOOK_URL" || -z "$WEBHOOK_SECRET" ]]; then
  exit 0
fi

should_deploy=0
after_sha=""

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/$WEBHOOK_BRANCH" && "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
    should_deploy=1
    after_sha="$local_sha"
  fi
done

if [[ "$should_deploy" != "1" ]]; then
  exit 0
fi

(
  sleep "$WEBHOOK_DELAY_SECONDS"

  payload="$(printf '{"ref":"refs/heads/%s","repository":{"full_name":"maysotoledo/siard"},"after":"%s"}' "$WEBHOOK_BRANCH" "$after_sha")"
  signature="$(printf '%s' "$payload" | openssl dgst -sha256 -hmac "$WEBHOOK_SECRET" -binary | xxd -p -c 256)"

  if curl --fail --silent --show-error \
    -X POST "$WEBHOOK_URL" \
    -H "Content-Type: application/json" \
    -H "X-GitHub-Event: push" \
    -H "X-Hub-Signature-256: sha256=$signature" \
    --data "$payload" \
    >/dev/null; then
    printf 'SIARD deploy webhook acionado para %s (%s -> %s)\n' "$WEBHOOK_BRANCH" "$REMOTE_NAME" "$REMOTE_URL"
  else
    printf 'Falha ao acionar SIARD deploy webhook para %s (%s -> %s)\n' "$WEBHOOK_BRANCH" "$REMOTE_NAME" "$REMOTE_URL" >&2
  fi
) &

disown || true
