#!/usr/bin/env python3
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
import hashlib
import hmac
import json
import os
import subprocess
import sys

SECRET = os.environ.get("SIARD_WEBHOOK_SECRET", "").encode()
DEPLOY_SCRIPT = os.environ.get("SIARD_DEPLOY_SCRIPT", "/usr/local/bin/siard-deploy")
LOG_FILE = os.environ.get("SIARD_DEPLOY_LOG", "/var/log/siard-deploy.log")
BRANCH = os.environ.get("SIARD_GIT_BRANCH", "main")
HOST = os.environ.get("SIARD_WEBHOOK_HOST", "0.0.0.0")
PORT = int(os.environ.get("SIARD_WEBHOOK_PORT", "9001"))


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        return

    def _send(self, code, body):
        try:
            self.send_response(code)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.end_headers()
            self.wfile.write(body.encode())
        except (BrokenPipeError, ConnectionResetError):
            pass

    def do_GET(self):
        if self.path == "/health":
            return self._send(200, "ok\n")

        return self._send(404, "not found\n")

    def do_POST(self):
        if self.path != "/github":
            return self._send(404, "not found\n")

        length = int(self.headers.get("Content-Length", "0"))
        body = self.rfile.read(length)

        signature = self.headers.get("X-Hub-Signature-256", "")
        expected = "sha256=" + hmac.new(SECRET, body, hashlib.sha256).hexdigest()
        if not SECRET or not hmac.compare_digest(signature, expected):
            return self._send(401, "invalid signature\n")

        event = self.headers.get("X-GitHub-Event", "")
        if event != "push":
            return self._send(202, "ignored event\n")

        try:
            payload = json.loads(body.decode("utf-8"))
        except Exception:
            return self._send(400, "invalid json\n")

        if payload.get("ref") != f"refs/heads/{BRANCH}":
            return self._send(202, "ignored branch\n")

        with open(LOG_FILE, "ab", buffering=0) as log:
            subprocess.Popen([DEPLOY_SCRIPT], stdout=log, stderr=log, start_new_session=True)

        return self._send(202, "deploy started\n")


if __name__ == "__main__":
    if not SECRET:
        print("SIARD_WEBHOOK_SECRET nao configurado.", file=sys.stderr)
        sys.exit(1)

    ThreadingHTTPServer((HOST, PORT), Handler).serve_forever()
